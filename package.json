{
  "name": "foresight-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Futuros foresight blog — public content hub (Signals of the Week + Foundations), static site generator.",
  "scripts": {
    "build": "node build.mjs",
    "serve": "npx --yes serve dist -l 8088",
    "dev": "node build.mjs && npx --yes serve dist -l 8088",
    "deploy": "wrangler deploy",
    "preview": "wrangler dev"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "wrangler": "^4.100.0"
  }
}
